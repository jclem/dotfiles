{
  "$schema": "vscode://schemas/color-theme",
  "name": "Folio Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#1C1B18",
    "editor.foreground": "#D5D2C8",
    "editorCursor.foreground": "#D5D2C8",
    "editorLineNumber.foreground": "#5E5B50",
    "editorLineNumber.activeForeground": "#C4A882",
    "editor.selectionBackground": "#3A3428",
    "editor.inactiveSelectionBackground": "#302E29",
    "editorIndentGuide.background": "#3D3A34",
    "editorIndentGuide.activeBackground": "#5E5B50",
    "editorRuler.foreground": "#302E29",
    "editorBracketMatch.background": "#3A3428",
    "editorBracketMatch.border": "#C4A882",
    "editor.findMatchBackground": "#3A3428",
    "editor.findMatchHighlightBackground": "#302E29",
    "editor.lineHighlightBackground": "#252420",
    "sideBar.background": "#252420",
    "sideBar.foreground": "#B0AD9F",
    "sideBar.border": "#3D3A34",
    "sideBarTitle.foreground": "#B0AD9F",
    "activityBar.background": "#302E29",
    "activityBar.foreground": "#B0AD9F",
    "activityBar.inactiveForeground": "#5E5B50",
    "activityBarBadge.background": "#C4A882",
    "activityBarBadge.foreground": "#1C1B18",
    "list.activeSelectionBackground": "#3A3428",
    "list.activeSelectionForeground": "#D5D2C8",
    "list.hoverBackground": "#302E29",
    "list.focusBackground": "#302E29",
    "list.inactiveSelectionBackground": "#302E29",
    "list.inactiveSelectionForeground": "#D5D2C8",
    "list.highlightForeground": "#C4A882",
    "input.background": "#302E29",
    "input.foreground": "#D5D2C8",
    "input.border": "#3D3A34",
    "input.placeholderForeground": "#5E5B50",
    "quickInput.background": "#252420",
    "quickInput.foreground": "#D5D2C8",
    "quickInputTitle.background": "#252420",
    "quickInputList.focusBackground": "#3A3428",
    "quickInputList.focusForeground": "#D5D2C8",
    "quickInputList.focusIconForeground": "#C4A882",
    "pickerGroup.foreground": "#8A8778",
    "pickerGroup.border": "#3D3A34",
    "dropdown.background": "#252420",
    "dropdown.foreground": "#D5D2C8",
    "dropdown.border": "#3D3A34",
    "editorGroupHeader.tabsBackground": "#252420",
    "tab.activeBackground": "#1C1B18",
    "tab.activeForeground": "#D5D2C8",
    "tab.inactiveBackground": "#252420",
    "tab.inactiveForeground": "#8A8778",
    "tab.border": "#302E29",
    "statusBar.background": "#302E29",
    "statusBar.foreground": "#B0AD9F",
    "titleBar.activeBackground": "#252420",
    "titleBar.activeForeground": "#D5D2C8",
    "titleBar.inactiveBackground": "#252420",
    "titleBar.inactiveForeground": "#8A8778",
    "editorError.foreground": "#C86060",
    "editorWarning.foreground": "#C4A050",
    "editorInfo.foreground": "#7099BB",
    "editorHint.foreground": "#70A8A0",
    "editorGutter.addedBackground": "#2A3325",
    "editorGutter.deletedBackground": "#362525",
    "editorGutter.modifiedBackground": "#3A3428",
    "focusBorder": "#C4A882",
    "widget.border": "#5E5B50",
    "foreground": "#D5D2C8",
    "descriptionForeground": "#8A8778",
    "errorForeground": "#C86060",
    "icon.foreground": "#B0AD9F",
    "badge.background": "#C4A882",
    "badge.foreground": "#1C1B18",
    "button.background": "#C4A882",
    "button.foreground": "#1C1B18",
    "button.hoverBackground": "#D4B468",
    "scrollbarSlider.background": "#3D3A34",
    "scrollbarSlider.hoverBackground": "#5E5B50",
    "scrollbarSlider.activeBackground": "#8A8778"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#5E5B50", "fontStyle": "italic" } },
    { "scope": ["comment.line", "comment.block", "punctuation.definition.comment"], "settings": { "foreground": "#5E5B50", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#8AAA70" } },
    { "scope": ["string.quoted", "string.template"], "settings": { "foreground": "#8AAA70" } },
    { "scope": "constant.character.escape", "settings": { "foreground": "#70A8A0" } },
    { "scope": ["constant.numeric", "constant.language", "constant.other"], "settings": { "foreground": "#A882A8" } },
    { "scope": ["keyword", "keyword.control", "keyword.operator", "storage.type", "storage.modifier"], "settings": { "foreground": "#C86060" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#7099BB" } },
    { "scope": ["entity.name.type", "support.type", "support.class"], "settings": { "foreground": "#C4A050" } },
    { "scope": ["variable", "variable.parameter", "variable.other"], "settings": { "foreground": "#D5D2C8" } },
    { "scope": "variable.language", "settings": { "foreground": "#A882A8", "fontStyle": "italic" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#C4A050" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#C4A882" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#C4A882" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#B0AD9F" } },
    { "scope": "punctuation", "settings": { "foreground": "#8A8778" } },
    { "scope": "punctuation.definition", "settings": { "foreground": "#8A8778" } },
    { "scope": "support.constant", "settings": { "foreground": "#A882A8" } },
    { "scope": "markup.heading", "settings": { "foreground": "#C4A882", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.underline", "settings": { "fontStyle": "underline" } },
    { "scope": "markup.raw", "settings": { "foreground": "#70A8A0" } },
    { "scope": "markup.link", "settings": { "foreground": "#7099BB", "fontStyle": "underline" } },
    { "scope": "keyword.other.documentation", "settings": { "foreground": "#5E5B50", "fontStyle": "italic" } }
  ]
}
