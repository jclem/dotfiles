{
  "$schema": "vscode://schemas/color-theme",
  "name": "Folio Light",
  "type": "light",
  "colors": {
    "editor.background": "#FFFCF5",
    "editor.foreground": "#2B2924",
    "editorCursor.foreground": "#2B2924",
    "editorLineNumber.foreground": "#9C9889",
    "editorLineNumber.activeForeground": "#8B7355",
    "editor.selectionBackground": "#EDE4D0",
    "editor.inactiveSelectionBackground": "#E8E5DD",
    "editorIndentGuide.background": "#DDDAD2",
    "editorIndentGuide.activeBackground": "#9C9889",
    "editorRuler.foreground": "#E8E5DD",
    "editorBracketMatch.background": "#EDE4D0",
    "editorBracketMatch.border": "#8B7355",
    "editor.findMatchBackground": "#EDE4D0",
    "editor.findMatchHighlightBackground": "#E8E5DD",
    "editor.lineHighlightBackground": "#F4F1EA",
    "sideBar.background": "#F4F1EA",
    "sideBar.foreground": "#4D4A43",
    "sideBar.border": "#DDDAD2",
    "sideBarTitle.foreground": "#4D4A43",
    "activityBar.background": "#E8E5DD",
    "activityBar.foreground": "#4D4A43",
    "activityBar.inactiveForeground": "#9C9889",
    "activityBarBadge.background": "#8B7355",
    "activityBarBadge.foreground": "#FFFCF5",
    "list.activeSelectionBackground": "#EDE4D0",
    "list.activeSelectionForeground": "#2B2924",
    "list.hoverBackground": "#E8E5DD",
    "list.focusBackground": "#E8E5DD",
    "list.inactiveSelectionBackground": "#E8E5DD",
    "list.inactiveSelectionForeground": "#2B2924",
    "list.highlightForeground": "#8B7355",
    "input.background": "#E8E5DD",
    "input.foreground": "#2B2924",
    "input.border": "#DDDAD2",
    "input.placeholderForeground": "#9C9889",
    "quickInput.background": "#F4F1EA",
    "quickInput.foreground": "#2B2924",
    "quickInputTitle.background": "#E8E5DD",
    "quickInputList.focusBackground": "#EDE4D0",
    "quickInputList.focusForeground": "#2B2924",
    "quickInputList.focusIconForeground": "#8B7355",
    "pickerGroup.foreground": "#6E6A5F",
    "pickerGroup.border": "#DDDAD2",
    "dropdown.background": "#F4F1EA",
    "dropdown.foreground": "#2B2924",
    "dropdown.border": "#DDDAD2",
    "editorGroupHeader.tabsBackground": "#F4F1EA",
    "tab.activeBackground": "#FFFCF5",
    "tab.activeForeground": "#2B2924",
    "tab.inactiveBackground": "#F4F1EA",
    "tab.inactiveForeground": "#6E6A5F",
    "tab.border": "#E8E5DD",
    "statusBar.background": "#E8E5DD",
    "statusBar.foreground": "#4D4A43",
    "titleBar.activeBackground": "#F4F1EA",
    "titleBar.activeForeground": "#2B2924",
    "titleBar.inactiveBackground": "#F4F1EA",
    "titleBar.inactiveForeground": "#6E6A5F",
    "editorError.foreground": "#A04040",
    "editorWarning.foreground": "#8B7040",
    "editorInfo.foreground": "#4A6A8B",
    "editorHint.foreground": "#4A7A7A",
    "editorGutter.addedBackground": "#D5E0C8",
    "editorGutter.deletedBackground": "#E8D0C8",
    "editorGutter.modifiedBackground": "#EDE4D0",
    "focusBorder": "#8B7355",
    "quickInput.background": "#F4F1EA",
    "quickInput.foreground": "#2B2924",
    "quickInputTitle.background": "#F4F1EA",
    "quickInputList.focusBackground": "#EDE4D0",
    "quickInputList.focusForeground": "#2B2924",
    "quickInputList.focusIconForeground": "#8B7355",
    "pickerGroup.foreground": "#6E6A5F",
    "pickerGroup.border": "#DDDAD2",
    "widget.border": "#9C9889",
    "foreground": "#2B2924",
    "descriptionForeground": "#6E6A5F",
    "errorForeground": "#A04040",
    "icon.foreground": "#4D4A43",
    "badge.background": "#8B7355",
    "badge.foreground": "#FFFCF5",
    "button.background": "#8B7355",
    "button.foreground": "#FFFCF5",
    "button.hoverBackground": "#A08550",
    "scrollbarSlider.background": "#DDDAD2",
    "scrollbarSlider.hoverBackground": "#9C9889",
    "scrollbarSlider.activeBackground": "#6E6A5F"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#9C9889", "fontStyle": "italic" } },
    { "scope": ["comment.line", "comment.block", "punctuation.definition.comment"], "settings": { "foreground": "#9C9889", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#5A7A4A" } },
    { "scope": ["string.quoted", "string.template"], "settings": { "foreground": "#5A7A4A" } },
    { "scope": "constant.character.escape", "settings": { "foreground": "#4A7A7A" } },
    { "scope": ["constant.numeric", "constant.language", "constant.other"], "settings": { "foreground": "#7A5A7A" } },
    { "scope": ["keyword", "keyword.control", "keyword.operator", "storage.type", "storage.modifier"], "settings": { "foreground": "#A04040" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#4A6A8B" } },
    { "scope": ["entity.name.type", "support.type", "support.class"], "settings": { "foreground": "#8B7040" } },
    { "scope": ["variable", "variable.parameter", "variable.other"], "settings": { "foreground": "#2B2924" } },
    { "scope": "variable.language", "settings": { "foreground": "#7A5A7A", "fontStyle": "italic" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#8B7040" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#8B7355" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#8B7355" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#4D4A43" } },
    { "scope": "punctuation", "settings": { "foreground": "#6E6A5F" } },
    { "scope": "punctuation.definition", "settings": { "foreground": "#6E6A5F" } },
    { "scope": "support.constant", "settings": { "foreground": "#7A5A7A" } },
    { "scope": "markup.heading", "settings": { "foreground": "#8B7355", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.underline", "settings": { "fontStyle": "underline" } },
    { "scope": "markup.raw", "settings": { "foreground": "#4A7A7A" } },
    { "scope": "markup.link", "settings": { "foreground": "#4A6A8B", "fontStyle": "underline" } },
    { "scope": "keyword.other.documentation", "settings": { "foreground": "#9C9889", "fontStyle": "italic" } }
  ]
}
