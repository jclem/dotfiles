# macos-icon = paper

auto-update-channel = stable

shell-integration = fish
window-padding-x = 8

theme = dark:folio-dark,light:folio-light

# background-opacity = 0.8
# background-blur = true

font-family = Berkeley Mono Variable
font-variation = wdth=70
font-variation = wght=500
font-size = 14
# font-family = Monaspace Xenon
# font-feature = calt, liga, ss01, ss02, ss03, ss04, ss05, ss06, ss07, ss08, ss09, ss10
# font-size = 12
adjust-box-thickness = -2

mouse-hide-while-typing = true

quick-terminal-position = center
quick-terminal-size = 100%,100%
quick-terminal-animation-duration = 0.1

# 100MB of scrollback (this value is in bytes)
scrollback-limit = 10485760

window-save-state = always

# Split navigation
keybind = ctrl+super+h=goto_split:left
keybind = ctrl+super+j=goto_split:down
keybind = ctrl+super+k=goto_split:up
keybind = ctrl+super+l=goto_split:right
keybind = shift+super+d=new_split:down
keybind = super+d=new_split:right
keybind = cmd+alt+d=new_split:left
keybind = super+x=close_surface

# Tab navigation
keybind = ctrl+super+bracket_left=previous_tab
keybind = ctrl+super+bracket_right=next_tab

# Tab and pane shortcuts
keybind = super+w=close_tab
