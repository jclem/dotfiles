[alias]
	cm = commit
	co = checkout
	df = diff
	st = status
[commit]
	gpgsign = true
[user]
	name = {{ .user.name }}
	email = {{ .user.email }}{{ if .gpg.keyid }}
	signingkey = {{ .gpg.keyid }}
	{{- end }}

{{- if (eq .chezmoi.os "darwin") }}
[credential]
	helper = osxkeychain
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
{{- end }}
